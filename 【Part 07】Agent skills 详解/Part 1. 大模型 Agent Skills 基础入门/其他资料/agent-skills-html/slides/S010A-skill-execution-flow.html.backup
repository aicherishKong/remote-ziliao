<div class="slide">
    <div class="bg-dots"></div>
    <div class="bg-mesh"></div>

    <div class="content content-centered">
        <div class="animate-ready" data-delay="0">
            <span class="badge">执行流程</span>
        </div>

        <h2 class="animate-ready text-gradient-teal" data-delay="0.1" style="margin-top:16px;margin-bottom:14px;">
            Skills 触发与执行全流程
        </h2>

        <p class="animate-ready center-block" data-delay="0.2" style="max-width:900px;margin-bottom:20px;">
            以 frontend-design 为例，看 Agent 如何从用户输入到最终输出，完整演示渐进式披露机制。
        </p>

        <!-- 用户输入区 -->
        <div class="animate-ready center-block" data-delay="0.25" style="max-width:1000px;margin-bottom:24px;">
            <div style="background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:20px;">
                <p style="margin:0 0 12px 0;font-size:0.95rem;font-weight:600;color:var(--text-primary);">
                    💬 选择一个用户输入：
                </p>
                <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:center;">
                    <button class="prompt-btn btn" data-prompt="design-login" style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);">
                        帮我设计一个登录页面
                    </button>
                    <button class="prompt-btn btn" data-prompt="react-component" style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);">
                        写一个 React 组件
                    </button>
                    <button class="prompt-btn btn" data-prompt="optimize-button" style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);">
                        优化这个按钮样式
                    </button>
                    <button class="prompt-btn btn" data-prompt="analyze-code" style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);">
                        分析这段代码
                    </button>
                </div>
            </div>
        </div>

        <!-- 执行流程指示器 -->
        <div class="animate-ready center-block" data-delay="0.3" style="max-width:1100px;margin-bottom:24px;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <!-- 阶段1 -->
                <div class="stage-indicator" data-stage="1" style="flex:1;text-align:center;">
                    <div class="stage-circle" style="width:50px;height:50px;border-radius:50%;background:var(--bg-cool);border:2px solid var(--border);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-tertiary);transition:all 0.3s;">
                        1
                    </div>
                    <div style="font-size:0.85rem;font-weight:600;color:var(--text-secondary);">接收输入</div>
                </div>

                <!-- 箭头 -->
                <div style="flex:0 0 30px;color:var(--border);font-size:1.2rem;">→</div>

                <!-- 阶段2 -->
                <div class="stage-indicator" data-stage="2" style="flex:1;text-align:center;">
                    <div class="stage-circle" style="width:50px;height:50px;border-radius:50%;background:var(--bg-cool);border:2px solid var(--border);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-tertiary);transition:all 0.3s;">
                        2
                    </div>
                    <div style="font-size:0.85rem;font-weight:600;color:var(--text-secondary);">路由判断</div>
                </div>

                <!-- 箭头 -->
                <div style="flex:0 0 30px;color:var(--border);font-size:1.2rem;">→</div>

                <!-- 阶段3 -->
                <div class="stage-indicator" data-stage="3" style="flex:1;text-align:center;">
                    <div class="stage-circle" style="width:50px;height:50px;border-radius:50%;background:var(--bg-cool);border:2px solid var(--border);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-tertiary);transition:all 0.3s;">
                        3
                    </div>
                    <div style="font-size:0.85rem;font-weight:600;color:var(--text-secondary);">加载上下文</div>
                </div>

                <!-- 箭头 -->
                <div style="flex:0 0 30px;color:var(--border);font-size:1.2rem;">→</div>

                <!-- 阶段4 -->
                <div class="stage-indicator" data-stage="4" style="flex:1;text-align:center;">
                    <div class="stage-circle" style="width:50px;height:50px;border-radius:50%;background:var(--bg-cool);border:2px solid var(--border);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-tertiary);transition:all 0.3s;">
                        4
                    </div>
                    <div style="font-size:0.85rem;font-weight:600;color:var(--text-secondary);">执行工作流</div>
                </div>

                <!-- 箭头 -->
                <div style="flex:0 0 30px;color:var(--border);font-size:1.2rem;">→</div>

                <!-- 阶段5 -->
                <div class="stage-indicator" data-stage="5" style="flex:1;text-align:center;">
                    <div class="stage-circle" style="width:50px;height:50px;border-radius:50%;background:var(--bg-cool);border:2px solid var(--border);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-tertiary);transition:all 0.3s;">
                        5
                    </div>
                    <div style="font-size:0.85rem;font-weight:600;color:var(--text-secondary);">输出结果</div>
                </div>
            </div>
        </div>

        <!-- 详情展示区 -->
        <div class="animate-ready center-block" data-delay="0.35" style="max-width:1100px;margin-bottom:20px;">
            <div class="card" style="padding:20px;min-height:280px;max-height:350px;overflow-y:auto;">
                <div id="stage-content">
                    <p style="margin:0;color:var(--text-tertiary);text-align:center;">
                        👆 点击上方的用户输入，开始演示 Skills 执行流程
                    </p>
                </div>
            </div>
        </div>

        <!-- 控制按钮 -->
        <div class="animate-ready center-block" data-delay="0.4" style="max-width:600px;display:flex;gap:12px;justify-content:center;">
            <button id="prev-btn" class="btn" disabled style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);opacity:0.5;cursor:not-allowed;">
                ◀ 上一步
            </button>
            <button id="next-btn" class="btn" disabled style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);opacity:0.5;cursor:not-allowed;">
                下一步 ▶
            </button>
            <button id="auto-btn" class="btn" disabled style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);opacity:0.5;cursor:not-allowed;">
                ⏩ 一键演示
            </button>
            <button id="reset-btn" class="btn" disabled style="background:var(--bg-white);color:var(--text-primary);border:1px solid var(--border);opacity:0.5;cursor:not-allowed;">
                🔄 重置
            </button>
        </div>
    </div>
</div>

<style>
/* 阶段指示器激活状态 */
.stage-indicator.active .stage-circle {
    background: var(--teal) !important;
    border-color: var(--teal) !important;
    color: var(--text-white) !important;
    box-shadow: 0 0 0 4px var(--teal-pale);
}

.stage-indicator.completed .stage-circle {
    background: var(--teal-pale) !important;
    border-color: var(--teal) !important;
    color: var(--teal) !important;
}

/* 按钮启用状态 */
.btn:not(:disabled) {
    opacity: 1 !important;
    cursor: pointer !important;
}

.btn:not(:disabled):hover {
    background: var(--teal-pale) !important;
    border-color: var(--teal) !important;
    color: var(--teal) !important;
}
</style>
